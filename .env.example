SERVER_NAME=argus_server

TZ=UTC # Change to your timezone. This only affects some async tasks.

DEBUG=false
URL = https://...
HTTPS_ENABLED=true
SECRET_KEY=<GENERATE A SAFE SECRET KEY AND PLACE IT HERE>
DJANGO_ALLOWED_HOSTS=localhost 127.0.0.1 [::1]
OUTBOUND_PORT=8000
VITE_OUTBOUND_PORT=5173

# Uncomment these variables to automatically create an admin account using these credentials on startup.
# After your first successfull login you can remove these variables from your file for safety reasons.
#ADMIN_EMAIL=<ENTER YOUR EMAIL>
#ADMIN_PASSWORD=<YOUR SAFE PASSWORD>

# Database. SQLite is the recommended default and needs no extra container.
DATABASE_ENGINE=django.db.backends.sqlite3
DATABASE_NAME=/usr/src/data/db.sqlite3

# Optional PostgreSQL-style configuration. Requires a compatible database driver.
#DATABASE_ENGINE=django.db.backends.postgresql
#DATABASE_NAME=argus
#DATABASE_USER=argus
#DATABASE_PASSWORD=<INSERT A SAFE PASSWORD HERE>
#DATABASE_HOST=db
#DATABASE_PORT=5432

# Huey task queue. SQLite keeps the default deployment to one container.
HUEY_SQLITE_PATH=/usr/src/data/huey.sqlite3

# Gunicorn
WEB_CONCURRENCY=4

# Async task workers (Huey). Only used by the single-container (supervisord) setup.
TASK_WORKERS=1

# Catalog providers. Keys are optional for startup, but provider calls require them.
TMDB_API_KEY=
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/
TVDB_API_KEY=
CATALOG_SEARCH_CACHE_TTL=3600
CATALOG_MOVIE_SYNC_INTERVAL_DAYS=14
CATALOG_SHOW_SYNC_INTERVAL_DAYS=2
CATALOG_ENDED_SHOW_SYNC_INTERVAL_DAYS=30

# Vite dev server. Only used when DJANGO_VITE_DEV_MODE is true (local/dev only).
DJANGO_VITE_DEV_MODE=false
DJANGO_VITE_DEV_SERVER_PORT=5173
DJANGO_VITE_DEV_SERVER_HOST=localhost

# OIDC Configuration. Uncomment the lines below if you want to add OIDC login to your instance.
#OIDC_CLIENT_NAME=""
#OIDC_CLIENT_ID=""
#OIDC_CLIENT_SECRET=""
#OIDC_SERVER_URL=""
#OIDC_ALLOW_SIGNUP=true
